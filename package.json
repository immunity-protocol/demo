{
  "name": "immunity-demo",
  "version": "0.1.0",
  "private": true,
  "description": "Demo orchestration for Immunity: 60-agent fleet, command queue, playground scenarios.",
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit -p agents/tsconfig.json && tsc --noEmit -p scripts/tsconfig.json",
    "build:agents": "tsc -p agents/tsconfig.json",
    "compose:generate": "tsx scripts/generate-compose.ts",
    "supervisor:generate": "tsx scripts/generate-supervisor-conf.ts",
    "threats:publish": "tsx --env-file=.env scripts/publish-threats.ts",
    "fund:og": "tsx --env-file=.env scripts/fund-agents-og.ts",
    "test:incidents": "tsx scripts/test-incidents.ts",
    "axl:up": "scripts/axl-spoke-host.sh up",
    "axl:down": "scripts/axl-spoke-host.sh down",
    "fleet": "scripts/fleet",
    "postinstall": "node scripts/patch-0g-broker.mjs"
  },
  "devDependencies": {
    "@immunity-protocol/sdk": "file:./.tarballs/immunity-protocol-sdk-0.6.3.tgz",
    "@types/node": "^20.14.0",
    "ethers": "^6.14.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "yaml": "^2.5.0"
  }
}
