# syntax=docker/dockerfile:1.7
#
# Packed-fleet image for Fly.io: 60 agent processes + axl-spoke gossip hub
# under one supervisord. Built and deployed via fly_fleet.toml.
#
# Stage layout:
#   1. axl-build : compile the axl daemon from source (Go)
#   2. agent-build : compile the agent TS to JS (Node)
#   3. runtime : alpine + node + supervisord, both binaries copied in
#
# Architecture note: Fly remote builders default to amd64. Building axl from
# source instead of pulling the upstream ghcr.io image keeps us self-contained
# (no GHCR auth) and arch-correct.

# ─── stage 1: axl daemon (Go) ────────────────────────────────────────────
ARG AXL_REF=9cba555ff0b8e14ebf1244ae02b274fbc4ec044e

FROM golang:1.25-alpine AS axl-build
ARG AXL_REF
RUN apk add --no-cache git
WORKDIR /src
RUN git clone https://github.com/gensyn-ai/axl.git axl \
 && cd axl \
 && git checkout "$AXL_REF" \
 && git rev-parse HEAD > /AXL_COMMIT
WORKDIR /src/axl
RUN go mod download \
 && go build -trimpath -ldflags="-s -w" -o /out/axl-hub ./cmd/node

# ─── stage 2: agent JS (Node) ────────────────────────────────────────────
FROM node:20-alpine AS agent-build
# Native build tools so the optional deps of `ws` (bufferutil, utf-8-validate)
# can compile. Without these, npm install fails on alpine which lacks python.
RUN apk add --no-cache python3 make g++
WORKDIR /app
# Copy the SDK tarball BEFORE npm install. agents/package.json's
# file:../.tarballs/... reference resolves against the parent of /app/agents
# inside the image, so we mirror that layout: tarball goes one level up.
COPY .tarballs /.tarballs
COPY agents/package.json ./
RUN npm install --legacy-peer-deps --no-audit --no-fund
# agents/tsconfig.json extends ../tsconfig.json so we need both. We mount
# the root one one level up and rewrite the extends to the absolute path.
COPY tsconfig.json /tsconfig.json
COPY agents/tsconfig.json ./
RUN sed -i 's|"../tsconfig.json"|"/tsconfig.json"|' tsconfig.json
COPY agents/src ./src
# Use the package.json `build` script so the post-tsc step that copies
# non-TS data files (agents/src/data/*.json — most importantly feeds.json
# loaded by the LLM-driven publisher) lands in dist/data/. Calling tsc
# directly skips the cp and the runtime crashes on the missing feeds.json
# import.
RUN npm run build

# ─── stage 3: runtime ────────────────────────────────────────────────────
FROM node:20-alpine AS runtime
RUN apk add --no-cache supervisor openssl ca-certificates

WORKDIR /app

# Axl daemon + per-agent spoke configs + per-agent keygen.
COPY --from=axl-build /out/axl-hub /usr/local/bin/axl-hub
COPY --from=axl-build /AXL_COMMIT /AXL_COMMIT
# Per-agent spoke configs and the roster the keygen iterates over.
COPY infrastructure/axl-spokes /etc/axl/spokes
COPY infrastructure/spoke-roster.txt /etc/axl/spoke-roster.txt
COPY infrastructure/generate-key.sh /usr/local/bin/generate-keys.sh
RUN chmod +x /usr/local/bin/generate-keys.sh /usr/local/bin/axl-hub

# Agent JS + dependencies.
COPY --from=agent-build /app/node_modules /app/node_modules
COPY --from=agent-build /app/dist /app/dist
COPY --from=agent-build /app/package.json /app/

# Supervisord config (60 spokes + 60 agents, generated from agents/src/wallets.ts).
COPY infrastructure/supervisord.conf /etc/supervisord.conf

ENV NODE_ENV=production LOG_LEVEL=info
# AXL spoke API ports: each agent connects to its own spoke at 9002 + ordinal.
EXPOSE 9002-9049

# /data is the Fly volume mount. generate-keys.sh runs once per boot,
# reading /etc/axl/spoke-roster.txt and ensuring /data/spoke-<agent_id>.pem
# exists for each — pre-existing keys are reused so peer ids stay stable
# across container restarts on the mounted volume.
ENTRYPOINT ["/bin/sh", "-c", "/usr/local/bin/generate-keys.sh && exec supervisord -c /etc/supervisord.conf -n"]
