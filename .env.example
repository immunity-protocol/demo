# ========================================================================
# Immunity demo fleet — environment template
# ========================================================================
# Copy to `.env` and fill in. The .env file is git-ignored.
#
# This config drives both the orchestration scripts (publish-threats,
# fund-agents-og, generate-compose) and the agent containers themselves
# via docker-compose's `env_file:`.

# ------------------------------------------------------------------------
# Demo wallet derivation
# ------------------------------------------------------------------------
# BIP-39 mnemonic that derives all 60 agent wallets via path
# m/44'/60'/0'/0/<index>. Indices: traders 0-49, wolves 50-52,
# publishers 53-57, watcher 58, scenario 59.
#
# WARNING: This is a public test mnemonic. Never use a real one here.
MASTER_SEED="abandon abandon abandon abandon abandon abandon abandon abandon abandon abandon abandon about"

# ------------------------------------------------------------------------
# 0G Galileo testnet
# ------------------------------------------------------------------------
GALILEO_RPC_URL=https://evmrpc-testnet.0g.ai
GALILEO_CHAIN_ID=16602
REGISTRY_ADDRESS=0x6FfB52ea1a01ABDe2793f6fca2Ea6661ca75903c
MOCK_USDC_ADDRESS=0x53d4Df2832A97Ec455D1d0ACe9242baE78f19eC9

# Funded wallet that pays OG gas to all 60 agents on first startup.
# Keep at least 30 OG in this wallet (0.5 OG per agent x 60).
DEPLOYER_PRIVATE_KEY=

# ------------------------------------------------------------------------
# AXL spoke (local)
# ------------------------------------------------------------------------
# All agents in the fleet talk to one local spoke container, which dials
# both team-operated hubs. URL is the spoke's HTTP API on the docker network.
AXL_URL=http://axl-spoke:9002

# ------------------------------------------------------------------------
# Postgres (the running app's database)
# ------------------------------------------------------------------------
# Agents pick up commands from demo.commands and write heartbeats to
# demo.agent_heartbeat. Same connection string the immunity-app uses.
DATABASE_URL=postgres://dev:dev@immunity_database:5432/immunity

# ------------------------------------------------------------------------
# Behavior tuning (optional; defaults shown)
# ------------------------------------------------------------------------
AGENT_TICK_MIN_MS=15000
AGENT_TICK_MAX_MS=90000
USDC_FUND_TARGET=250000
OG_FUND_TARGET=0.5
